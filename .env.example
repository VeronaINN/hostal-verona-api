# Railway crea DATABASE_URL automaticamente cuando agregas el plugin
# de PostgreSQL a tu proyecto — no necesitas escribirla a mano ahi.
#
# Para correr el backend en tu computadora, copia este archivo a ".env"
# y coloca la cadena de conexion de tu propia base de datos Postgres
# (local o de Railway, copiada desde la pestaña "Connect" del plugin).
DATABASE_URL=postgresql://usuario:contrasena@host:5432/nombre_basedatos

# Railway asigna PORT automaticamente; en local puedes dejarlo en 3000.
PORT=3000
