# Variables para la variante MySQL (server-mysql.js), pensada para
# Hostinger u otro hosting compartido. Los valores DB_* los encuentras
# en hPanel -> Bases de datos -> MySQL (crea una base de datos ahi
# primero si todavia no tienes una).
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_contrasena_mysql
DB_NAME=tu_basededatos

# El puerto que te asigne Hostinger para la app Node (si te deja elegirlo,
# usa 3000; si te lo asigna automatico, usa esa variable tal cual la des).
PORT=3000
